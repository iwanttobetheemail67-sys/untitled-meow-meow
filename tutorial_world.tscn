offset_left = -4173.0
offset_top = -1.0
offset_right = -3277.0
offset_bottom = 295.0
theme_override_font_sizes/font_size = 30
text = "Your score multiplier will increase by 0.1x every 5 seconds,
 your score will increase every 0.5 seconds, and the object
 fall speed will increase by 10 every 0.5 seconds 
(20 with fast falling, and 30 with hard mode)
fall speed is capped at 25000 unless set higher by cheats"

