theme_override_font_sizes/font_size = 35
text = "The goal of the game is to get the
 highest score possible. this is done by
avoiding harmful objects and collecting
good objects. The game will end when
your HP reaches zero, you fall off the
edge, or you touch a death skull"

[node name="Label8" type="Label" parent="tutorial text"]
